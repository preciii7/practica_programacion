    "class Persona:\n",
    "    def __init__(self, nombre, edad):\n",
    "        self.nombre = nombre\n",
    "        self.edad=edad\n",
    "    def saludar(self):\n",
    "        return f\"Hola {self.nombre}\"\n",
    "\n",
    "cliente = Persona(\"Pepito\", \"30\")\n",
    "\n",
    "print(cliente.saludar())\n"
   ]
